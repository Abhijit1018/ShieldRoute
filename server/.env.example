# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/shieldroute"
# Neon format example:
# DATABASE_URL="postgresql://<user>:<password>@<host>/<db_name>?sslmode=require&channel_binding=require"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Redis (for real-time trigger state)
REDIS_URL=redis://localhost:6379

# OTP (MSG91 or Twilio)
OTP_PROVIDER=mock
OTP_MOCK_FALLBACK=true

# MSG91
MSG91_AUTH_KEY=your_msg91_key
MSG91_TEMPLATE_ID=your_template_id

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_PHONE=+1xxxxxxxxxx

# Razorpay (Phase 2 - payments)
PAYMENT_PROVIDER=mock
PAYMENT_MOCK_FALLBACK=true
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Weather API (Phase 2)
OPENWEATHER_API_KEY=your_openweather_key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
# Optional extra origins (comma-separated)
# Example: FRONTEND_URLS=https://shieldroute.netlify.app,https://staging-shieldroute.netlify.app
FRONTEND_URLS=
